    <h3>EHDSProcedure → ProcedureEuCore</h3>
    <a>  </a>
    <p></p>
    <p>
  This page explains how conceptual elements from the EHDS logical model are expressed
  in the corresponding FHIR ProcedureEuCore profile used by this Implementation Guide.
    </p>
    <p></p>
    <div class="table-wrap">
      <strong>Mapping Context</strong>
      <ul>
        <li>
          <strong>Source logical model:</strong>
          <a href="https://www.xt-ehr.eu/fhir/models/0.3.0/StructureDefinition-EHDSProcedure.html" target="_blank">
        EHDSProcedure
          </a>
        </li>
        <li>
          <strong>Target FHIR profile:</strong>
          <a href="StructureDefinition-procedure-eu-core.html">
        ProcedureEuCore
          </a>
        </li>
      </ul>
    </div>
    <p></p>
    <div class="table-wrap">
      <table summary="EHDSProcedure → ProcedureEuCore">
        <caption>EHDSProcedure → ProcedureEuCore</caption>
        <thead>
          <tr>
            <th colspan="1" class="src-head">EHDSProcedure (Logical Model)</th>
            <th class="relhead">Relationship</th>
            <th colspan="3" class="tgt-head">ProcedureEuCore</th>
          </tr>
          <tr>
            <th class="src-sub">Element</th>
            <th class="relsub">Relation</th>
            <th class="tgt-sub">Resource</th>
            <th class="tgt-sub">Element</th>
            <th class="tgt-sub">Notes</th>
          </tr>
        </thead>
        <tbody>
          <!-- HEADER BLOCK (from EHDSDataSet) -->
          <tr>
            <td>header</td>
            <td>related-to</td>
            <td>Procedure</td><td>.</td>
            <td>Dataset-level; not usually carried in Procedure as-is.</td>
          </tr>
          <tr>
            <td>header.subject</td>
            <td>equivalent</td>
            <td>Procedure</td><td>subject</td>
            <td>Reference to Patient (or other subject) as in FHIR Procedure.subject.</td>
          </tr>
          <tr>
            <td>header.identifier</td>
            <td>equivalent</td>
            <td>Procedure</td><td>identifier</td>
            <td>Copy all identifiers if multiple exist.</td>
          </tr>
          <tr>
            <td>header.author[x]</td>
            <td>equivalent</td>
            <td>Procedure</td><td>recorder</td>
            <td></td>
          </tr>
          <tr>
            <td>header.date</td>
            <td>equivalent</td>
            <td>Procedure</td><td>extension:recorded <span style="color:#2e7d32;font-weight:600;">〔R4〕</span><br></br>recorded <span style="color:#2e7d32;font-weight:600;">〔R5〕</span></td>
            <td></td>
          </tr>
          <tr>
            <td>header.status</td>
            <td>no-map</td>
            <td>Procedure</td><td>status</td>
            <td></td>
          </tr>
          <tr>
            <td>header.source</td>
            <td>no-map</td>
            <td>Procedure</td><td>asserter<span style="color:#2e7d32;font-weight:600;">〔R4〕</span><br></br>reportedReference<span style="color:#2e7d32;font-weight:600;">〔R5〕</span></td>
            <td></td>
          </tr>
          <tr>
            <td>header.language</td>
            <td>equivalent</td>
            <td>Procedure</td><td>language</td>
            <td></td>
          </tr>
          <!-- code -->
          <tr>
            <td>code</td>
            <td>equivalent</td>
            <td>Procedure</td><td>code</td>
            <td></td>
          </tr>
          <!-- procedureDate[x] -->
          <tr>
            <td>procedureDate[x]</td>
            <td>equivalent</td>
            <td>Procedure</td><td>performed[x]<span style="color:#2e7d32;font-weight:600;">〔R4〕</span><br></br>occurrence[x]<span style="color:#2e7d32;font-weight:600;">〔R5〕</span></td>
            <td>Use <code>performedDateTime</code> or <code>performedPeriod</code> according to actual data type. <code>performed[x]</code> used in R4, <code>occurrence[x]</code> used in R5<br></br>Use <code>occurrenceDateTime</code> or <code>occurrencePeriod</code> according to actual data type. <code>performed[x]</code> used in R4, <code>occurrence[x]</code> used in R5</td>
          </tr>
          <!-- procedureDate[x] -->
          <!-- performer -->
          <tr>
            <td>performer</td>
            <td>equivalent</td>
            <td>Procedure</td><td>performer</td>
            <td>FHIR Procedure.performer.actor → Practitioner / PractitionerRole / Organization; add role if available.</td>
          </tr>
          <!-- bodySite -->
          <tr>
            <td>bodySite</td>
            <td>equivalent</td>
            <td>Procedure</td><td>bodySite</td>
            <td>Map EHDSBodyStructure → one or more <code>Procedure.bodySite</code>; laterality as qualifier.</td>
          </tr>
          <!-- reason[x] -->
          <tr>
            <td>reason[x]</td>
            <td>equivalent</td>
            <td>Procedure</td><td>reasonCode / reasonReference<span style="color:#2e7d32;font-weight:600;">〔R4〕</span><br></br>reason <span style="color:#2e7d32;font-weight:600;">〔R5〕</span></td>
            <td>In R4, codes go to <code>reasonCode</code>; references (Condition / Observation / Procedure) go to <code>reasonReference</code>.<br></br>In R5 use the CodeableReference <code>reason</code>.</td>
          </tr>
          <!-- outcome -->
          <tr>
            <td>outcome</td>
            <td>equivalent</td>
            <td>Procedure</td><td>outcome</td>
            <td>CodeableConcept; EHDS prefers SNOMED CT.</td>
          </tr>
          <!-- complication -->
          <tr>
            <td>complication</td>
            <td>equivalent</td>
            <td>Procedure</td><td>complication / complicationDetail <span style="color:#2e7d32;font-weight:600;">〔R4〕</span><br></br>complication<span style="color:#2e7d32;font-weight:600;">〔R5〕</span></td>
            <td>In R4 codes go to <code>complication</code>; reference (Condition) in <code>complicationDetail</code>.<br></br>In R5 use the CodeableReference <code>complication</code>.</td>
          </tr>
          <!-- deviceUsed -->
          <tr>
            <td>deviceUsed</td>
            <td>equivalent</td>
            <td>Procedure</td><td>usedCode / usedReference<span style="color:#2e7d32;font-weight:600;">〔R4〕</span><br></br>used<span style="color:#2e7d32;font-weight:600;">〔R5〕</span></td>
            <td>In R4 <code>usedCode</code> only if you have no Device instance, <code>usedReference</code> if you refer a Device.<br></br>In R5 use the CodeableReference <code>used</code>.</td>
          </tr>
          <!-- focalDevice -->
          <tr>
            <td>focalDevice</td>
            <td>equivalent</td>
            <td>Procedure</td><td>focalDevice.manipulated</td>
            <td>Matches FHIR Procedure.focalDevice exactly.</td>
          </tr>
          <!-- note -->
          <tr>
            <td>note</td>
            <td>equivalent</td>
            <td>Procedure</td><td>note</td>
            <td>EHDS has 0..1 string; FHIR allows 0..* Annotation → map to one Annotation entry.</td>
          </tr>
        </tbody>
      </table>
    </div>
    <p style="margin-top:2rem;color:#555;">
      Return to overview: <a href="modelmap.html">EHDS Logical Models → FHIR Profiles</a>
    </p>
  </body>
